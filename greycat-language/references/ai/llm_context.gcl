/// llama.cpp Advanced Context API for GreyCat
///
/// This file provides low-level access to llama.cpp contexts for expert users
/// who need fine-grained control over KV cache, sequences, batching, and state.
///
/// Most users should use the high-level Model API (llm_model.gcl) instead.
/// Use this API when you need:
/// - Multi-turn conversations with explicit KV cache management
/// - Parallel sequence processing (multiple conversations simultaneously)
/// - Custom batching strategies
/// - State save/restore for long-running sessions
/// - Manual memory management
///
/// Basic workflow:
/// ```
/// var model = Model::load("./model.gguf", null);
/// var ctx = Context::create(model, ContextParams { n_ctx: 4096 });
///
/// // Tokenize and create batch
/// var tokens = model.tokenize("Hello world", true, false);
/// var batch = Batch::from_array(tokens, 0, 0);
///
/// // Decode
/// ctx.decode(batch);
///
/// // Get logits and sample
/// var logits = ctx.get_logits(0);
///
/// // Cleanup
/// ctx.free();
/// ```

// ============================================================================
// SEQUENCE ID TYPE
// ============================================================================

/// Sequence identifier
///
/// Sequences are independent conversation threads in the same context.
/// Multiple sequences can be processed in parallel using batching.
type SeqId {
    /// Sequence ID value (0 to n_seq_max-1)
    id: int;
}

// ============================================================================
// BATCH TYPE
// ============================================================================

/// Token batch for inference
///
/// Represents a batch of tokens to be processed by the context.
/// Supports single-sequence (simple) and multi-sequence (advanced) batching.
///
/// Simple single-sequence usage:
/// ```
/// var batch = Batch::from_array(tokens, 0, 0);
/// ctx.decode(batch);
/// ```
///
/// Advanced multi-sequence usage:
/// ```
/// var batch = Batch::create(512, 0, 2);  // 512 tokens, 2 sequences
/// batch.add_token(token1, 0, [SeqId { id: 0 }], true);
/// batch.add_token(token2, 0, [SeqId { id: 1 }], true);
/// ctx.decode(batch);
/// batch.free();
/// ```
type Batch {
    /// Create empty batch with capacity
    ///
    /// - n_tokens: Maximum number of tokens
    /// - embd: Embedding dimension (0 for token IDs, >0 for embeddings)
    /// - n_seq_max: Maximum number of sequences
    static native fn create(n_tokens: int, embd: int, n_seq_max: int): Batch;

    /// Create batch from token array (simple single-sequence)
    ///
    /// - tokens: Array of token IDs
    /// - pos_start: Starting position in sequence
    /// - seq_id: Sequence ID (usually 0)
    static native fn from_array(tokens: Array<int>, pos_start: int, seq_id: int): Batch;

    /// Add token to batch
    ///
    /// - token: Token ID
    /// - pos: Position in sequence
    /// - seq_ids: Array of sequence IDs this token belongs to
    /// - logits: Whether to compute logits for this token
    native fn add_token(token: int, pos: int, seq_ids: Array<SeqId>, logits: bool);

    /// Add embedding to batch
    ///
    /// - embd: Embedding vector
    /// - pos: Position in sequence
    /// - seq_ids: Array of sequence IDs
    /// - logits: Whether to compute logits
    native fn add_embedding(embd: Array<float>, pos: int, seq_ids: Array<SeqId>, logits: bool);

    /// Clear batch contents
    native fn clear();

    /// Get number of tokens in batch
    native fn size(): int;

    /// Free batch resources (or let GC handle it)
    native fn free();
}

// ============================================================================
// CONTEXT TYPE - Advanced KV Cache Management
// ============================================================================

/// Inference context with KV cache
///
/// Provides low-level control over inference, KV cache, and sequence management.
/// Each context has its own KV cache and can handle multiple sequences.
///
/// Example: Multi-turn conversation with cache management
/// ```
/// var ctx = Context::create(model, ContextParams { n_ctx: 2048 });
///
/// // First turn
/// var tokens1 = model.tokenize("User: Hello!", true, false);
/// var batch1 = Batch::from_array(tokens1, 0, 0);
/// ctx.decode(batch1);
///
/// // Generate response...
///
/// // Second turn (continue sequence)
/// var tokens2 = model.tokenize("User: How are you?", false, false);
/// var batch2 = Batch::from_array(tokens2, previous_len, 0);
/// ctx.decode(batch2);
/// ```
type Context {
    // ========================================================================
    // STATIC: Context Creation
    // ========================================================================

    /// Create context from model
    ///
    /// Creates a new inference context with the specified parameters.
    /// Returns null if creation fails.
    static native fn create(model: Model, params: ContextParams?): Context;

    // ========================================================================
    // INSTANCE: Context Properties
    // ========================================================================

    /// Get context size
    ///
    /// Returns the actual context size (may differ from requested).
    native fn n_ctx(): int;

    /// Get batch size
    native fn n_batch(): int;

    /// Get ubatch size
    native fn n_ubatch(): int;

    /// Get max sequences
    native fn n_seq_max(): int;

    /// Get sequence-specific context size
    native fn n_ctx_seq(): int;

    /// Get embedding dimension
    native fn n_embd(): int;

    /// Get vocabulary size
    native fn n_vocab(): int;

    /// Get pooling type
    native fn pooling_type(): PoolingType;

    /// Get number of threads used for generation (single token)
    native fn n_threads(): int;

    /// Get number of threads used for batch processing (multiple tokens)
    native fn n_threads_batch(): int;

    // ========================================================================
    // INSTANCE: Dynamic Configuration
    // ========================================================================

    /// Set number of threads for generation and batch processing
    ///
    /// Allows dynamic adjustment of thread count during execution.
    /// - n_threads: Number of threads for generation (single token)
    /// - n_threads_batch: Number of threads for batch processing
    native fn set_n_threads(n_threads: int, n_threads_batch: int);

    /// Set whether context outputs embeddings
    ///
    /// Toggle embeddings computation on or off.
    native fn set_embeddings(enabled: bool);

    /// Set whether to use causal attention
    ///
    /// If true, the model will only attend to past tokens.
    native fn set_causal_attn(enabled: bool);

    /// Set warmup mode
    ///
    /// If true, all model tensors are activated during decode to load and cache weights.
    native fn set_warmup(enabled: bool);

    /// Wait until all computations are finished
    ///
    /// Automatically called when getting results. Usually not needed explicitly.
    native fn synchronize();

    // ========================================================================
    // INSTANCE: Inference
    // ========================================================================

    /// Encode tokens (for encoder models)
    ///
    /// Processes a batch through the encoder.
    /// Returns 0 on success, non-zero on error.
    native fn encode(batch: Batch): int;

    /// Decode tokens (for decoder models)
    ///
    /// Processes a batch through the decoder.
    /// Returns 0 on success, 1 if no KV slot available.
    native fn decode(batch: Batch): int;

    // ========================================================================
    // INSTANCE: Logits and Embeddings Access
    // ========================================================================

    /// Get logits for sequence position
    ///
    /// Returns logits for the token at the specified batch index.
    /// - i: Batch index (-1 = last token)
    native fn get_logits(i: int): Array<float>;

    /// Get embeddings for sequence position
    ///
    /// Returns embedding vector for the token at batch index i.
    native fn get_embeddings(i: int): Array<float>;

    /// Get pooled embeddings for sequence
    ///
    /// Returns pooled embedding for the entire sequence.
    native fn get_embeddings_seq(seq_id: SeqId): Array<float>;

    // ========================================================================
    // INSTANCE: KV Cache Management
    // ========================================================================

    /// Clear entire KV cache
    ///
    /// Removes all tokens from all sequences.
    native fn kv_cache_clear();

    /// Remove tokens from sequence
    ///
    /// Removes tokens in range [p0, p1) from the specified sequence.
    /// - seq_id: Sequence ID
    /// - p0: Start position (inclusive)
    /// - p1: End position (exclusive, -1 = end of sequence)
    native fn kv_cache_seq_rm(seq_id: SeqId, p0: int, p1: int);

    /// Copy sequence
    ///
    /// Copies tokens from src sequence to dst sequence.
    /// - src: Source sequence ID
    /// - dst: Destination sequence ID
    /// - p0: Start position (inclusive)
    /// - p1: End position (exclusive, -1 = end of sequence)
    native fn kv_cache_seq_cp(src: SeqId, dst: SeqId, p0: int, p1: int);

    /// Keep only specified sequences
    ///
    /// Removes all sequences except those in the keep list.
    native fn kv_cache_seq_keep(keep: Array<SeqId>);

    /// Shift sequence positions
    ///
    /// Adds delta to all positions in range [p0, p1) for the sequence.
    /// Used for context shifting.
    native fn kv_cache_seq_add(seq_id: SeqId, p0: int, p1: int, delta: int);

    /// Divide sequence positions
    ///
    /// Divides all positions in range [p0, p1) by d for the sequence.
    /// Integer division: pos[i] = pos[i] / d
    native fn kv_cache_seq_div(seq_id: SeqId, p0: int, p1: int, d: int);

    /// Get max contiguous position in sequence
    ///
    /// Returns the highest position with continuous tokens in the sequence.
    native fn kv_cache_seq_pos_max(seq_id: SeqId): int;

    /// Get min contiguous position in sequence
    ///
    /// Returns the smallest position present in the memory for the sequence.
    /// Typically non-zero only for SWA caches. Returns -1 if sequence is empty.
    native fn kv_cache_seq_pos_min(seq_id: SeqId): int;

    /// Check if KV cache memory supports shifting
    ///
    /// Returns true if the memory implementation supports position shifting.
    native fn kv_cache_can_shift(): bool;

    /// Update KV cache
    ///
    /// Updates internal KV cache state. Call after manual cache manipulation.
    native fn kv_cache_update();

    /// Defragment KV cache
    ///
    /// Defragments the KV cache to reduce fragmentation and improve memory efficiency.
    /// Call this periodically in long-running sessions with many sequence operations.
    native fn kv_cache_defrag();

    /// Check if KV cache supports sequences
    ///
    /// Returns true if the memory implementation supports multiple sequences.
    /// Some memory backends may not support sequence operations.
    native fn kv_cache_can_use_seqs(): bool;

    // ========================================================================
    // INSTANCE: State Management
    // ========================================================================

    /// Get state size in bytes
    ///
    /// Returns the size needed to save the current state.
    native fn get_state_size(): int;

    /// Save state to bytes
    ///
    /// Saves the current inference state (KV cache, etc.) to a byte array.
    /// Returns StateData containing the state.
    native fn get_state(): StateData;

    /// Restore state from bytes
    ///
    /// Restores inference state from previously saved data.
    native fn set_state(state: StateData);

    /// Load state from file
    ///
    /// Loads state from a file on disk.
    native fn load_state(path: String);

    /// Save state to file
    ///
    /// Saves current state to a file on disk.
    native fn save_state(path: String);

    // ========================================================================
    // INSTANCE: Sequence State Management (Partial)
    // ========================================================================

    /// Get size needed to save sequence state
    native fn get_state_seq_size(seq_id: SeqId): int;

    /// Save sequence state
    ///
    /// Saves state for a single sequence.
    native fn get_state_seq(seq_id: SeqId): StateData;

    /// Restore sequence state
    ///
    /// Restores state for a single sequence.
    native fn set_state_seq(seq_id: SeqId, state: StateData);

    /// Save sequence state to file
    ///
    /// Saves state for a single sequence directly to a file on disk.
    /// More efficient than get_state_seq() + manual file write for large states.
    ///
    /// - path: File path to save state to
    /// - seq_id: Sequence ID to save
    /// - tokens: Token context for the sequence (optional)
    ///
    /// Returns the number of bytes written.
    native fn save_state_seq_file(path: String, seq_id: SeqId, tokens: Array<int>?): int;

    /// Load sequence state from file
    ///
    /// Loads state for a single sequence directly from a file on disk.
    /// More efficient than manual file read + set_state_seq() for large states.
    ///
    /// - path: File path to load state from
    /// - seq_id: Destination sequence ID
    ///
    /// Returns the number of bytes read.
    native fn load_state_seq_file(path: String, seq_id: SeqId): int;

    // ========================================================================
    // INSTANCE: Partial State Management
    // ========================================================================

    /// Get size needed to save sequence state with flags
    ///
    /// Like get_state_seq_size(), but supports partial state (SWA-only, etc.)
    /// - flags: State flags (1 = SWA/partial only)
    native fn get_state_seq_size_ext(seq_id: SeqId, flags: int): int;

    /// Save sequence state with flags
    ///
    /// Like get_state_seq(), but supports partial state.
    /// - flags: State flags (1 = SWA/partial only)
    native fn get_state_seq_ext(seq_id: SeqId, flags: int): StateData;

    /// Restore sequence state with flags
    ///
    /// Like set_state_seq(), but supports partial state.
    /// - flags: State flags (1 = SWA/partial only)
    native fn set_state_seq_ext(seq_id: SeqId, state: StateData, flags: int);

    // ========================================================================
    // INSTANCE: Performance
    // ========================================================================

    /// Get performance metrics
    ///
    /// Returns timing data for this context's operations.
    native fn perf(): PerfData;

    /// Reset performance counters
    native fn perf_reset();

    /// Print memory usage
    ///
    /// Logs detailed memory breakdown to llama.cpp logger.
    native fn print_memory();

    // ========================================================================
    // INSTANCE: LoRA Adapter Management
    // ========================================================================

    /// Apply LoRA adapter to context
    ///
    /// Applies a LoRA adapter to this context with the specified scale.
    /// Multiple adapters can be applied to the same context.
    ///
    /// - adapter: LoRA adapter to apply
    /// - scale: Scaling factor (0.0-1.0, typically 1.0)
    ///
    /// Returns 0 on success, non-zero on error.
    native fn apply_lora_adapter(adapter: LoraAdapter, scale: float): int;

    /// Remove LoRA adapter from context
    ///
    /// Removes a previously applied LoRA adapter from this context.
    ///
    /// - adapter: LoRA adapter to remove
    ///
    /// Returns 0 on success, non-zero on error.
    native fn remove_lora_adapter(adapter: LoraAdapter): int;

    /// Clear all LoRA adapters from context
    ///
    /// Removes all LoRA adapters, returning context to base model state.
    native fn clear_lora_adapters();

    // ========================================================================
    // INSTANCE: Control Vectors
    // ========================================================================

    /// Apply control vector to context
    ///
    /// Applies a control vector to steer model behavior.
    /// Control vectors are per-layer adjustments to embeddings.
    ///
    /// - data: Control vector data (n_embd x n_layers, starting from layer 1)
    /// - n_embd: Embedding dimension
    /// - il_start: Start layer (inclusive)
    /// - il_end: End layer (inclusive)
    ///
    /// Pass null for data to clear the control vector.
    native fn apply_control_vector(
        data: Array<float>?,
        n_embd: int,
        il_start: int,
        il_end: int
    );

    // ========================================================================
    // INSTANCE: Resource Management
    // ========================================================================

    /// Free context resources
    ///
    /// Explicitly releases context memory. Optional - GC will handle cleanup.
    native fn free();
}
